<http://www.semanticweb.org/gonza/ontologies/2026/3/logistica> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#estaAsignadoA
:estaAsignadoA rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain :Paquete ;
               rdfs:range :Vehículo .


###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#tieneDestino
:tieneDestino rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Paquete ;
              rdfs:range :PuntoDeEntrega .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#matricula
:matricula rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Vehículo ;
           rdfs:range xsd:string .


###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#pesoKg
:pesoKg rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :Paquete ;
        rdfs:range xsd:float .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#Paquete
:Paquete rdf:type owl:Class .


###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#PuntoDeEntrega
:PuntoDeEntrega rdf:type owl:Class .


###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#Vehículo
:Vehículo rdf:type owl:Class .


###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica#Vehículo_Cargado
:Vehículo_Cargado rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Vehículo
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf :estaAsignadoA
                                                                              ] ;
                                                               owl:someValuesFrom :Paquete
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] .



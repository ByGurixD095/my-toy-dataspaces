@prefix : <http://www.semanticweb.org/gonza/ontologies/2026/3/logistica/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/gonza/ontologies/2026/3/logistica/> .

<http://www.semanticweb.org/gonza/ontologies/2026/3/logistica> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

:estaAsignadoA rdf:type owl:ObjectProperty ;
               rdfs:domain :Paquete ;
               rdfs:range :Vehículo .

#################################################################
#    Data properties
#################################################################

:matricula rdf:type owl:DatatypeProperty ;
           rdfs:domain :Vehículo ;
           rdfs:range xsd:string .

:pesoKg rdf:type owl:DatatypeProperty ;
        rdfs:domain :Paquete ;
        rdfs:range xsd:float .

#################################################################
#    Classes
#################################################################

:Paquete rdf:type owl:Class .
:Vehículo rdf:type owl:Class .

#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica/Furgoneta_01
:Furgoneta_01 rdf:type owl:NamedIndividual , :Vehículo ;
              :matricula "1234-ABC" .

###  http://www.semanticweb.org/gonza/ontologies/2026/3/logistica/Pedido_XYZ
:Pedido_XYZ rdf:type owl:NamedIndividual , :Paquete ;
            :estaAsignadoA :Furgoneta_01 ;
            :pesoKg "15.5"^^xsd:float .
